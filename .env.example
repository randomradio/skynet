# ──────────────────────────────────────────────
# Skynet Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
# Then fill in your values below.
#
# Quick start:
#   1. cp .env.example .env
#   2. docker compose up -d        # start MatrixOne database
#   3. pnpm install
#   4. pnpm db:setup               # create database + run migrations
#   5. pnpm dev                    # start the app
# ──────────────────────────────────────────────

# Database (MatrixOne — MySQL-compatible, port 6001)
# For local development with docker-compose: mysql://root:111@127.0.0.1:6001/skynet
DATABASE_URL="mysql://root:111@127.0.0.1:6001/skynet"

# GitHub OAuth (create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# Auth
JWT_SECRET="your_jwt_secret"

# GitHub Webhook (used to verify incoming webhooks)
GITHUB_WEBHOOK_SECRET="your_github_webhook_secret"

# GitHub Personal Access Token (for API calls: sync issues, PRs)
GITHUB_TOKEN="your_github_token"
# Optional timeout for OAuth calls to GitHub (milliseconds)
GITHUB_OAUTH_TIMEOUT_MS="15000"

# AI Provider (preferred): Zhipu GLM via Anthropic-compatible endpoint
ANTHROPIC_AUTH_TOKEN="your_zhipu_api_key"
ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.7"
ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
ANTHROPIC_DEFAULT_OPUS_MODEL="glm-4.7"

# Local skill hub directory (editable manifests loaded by API and mounted to containers)
SKILL_HUB_DIR=".skill-hub"

# App URL (used for OAuth callbacks, links, etc.)
# Local dev:          http://localhost:3000
# Cloudflare tunnel:  http://skynet.latentvibe.com
APP_URL="http://localhost:3000"

# Auto-sync interval for repository issue/PR cache warmup (milliseconds)
REPO_AUTO_SYNC_MIN_INTERVAL_MS="300000"

# NanoClaw runtime (required)
NANOCLAW_ROOT="/data/nanoclaw"
CONTEXT_BUNDLE_ROOT=".skynet-context"
NANOCLAW_DEV_IMAGE="skynet-nanoclaw-dev:latest"
NANOCLAW_REVIEW_IMAGE="skynet-nanoclaw-review:latest"
NANOCLAW_DEV_TIMEOUT_MIN="30"
NANOCLAW_REVIEW_TIMEOUT_MIN="15"
NANOCLAW_DEV_MEMORY_MB="4096"
NANOCLAW_REVIEW_MEMORY_MB="2048"

# NanoClaw shell API endpoint (served by sandbox container)
# Port must match docker-compose SANDBOX_PORT, default 8180
SANDBOX_URL="http://localhost:8180"

# Docker-only overrides (when running `docker compose up web`)
DATABASE_URL_DOCKER="mysql://root:111@matrixone:6001/skynet"
SANDBOX_URL_DOCKER="http://sandbox:8080"
WEB_PORT="3000"
