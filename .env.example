# ──────────────────────────────────────────────
# Skynet Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
# Then fill in your values below.
#
# Quick start:
#   1. cp .env.example .env
#   2. docker compose up -d        # start MatrixOne database
#   3. pnpm install
#   4. pnpm db:setup               # create database + run migrations
#   5. pnpm dev                    # start the app
# ──────────────────────────────────────────────

# Database (MatrixOne — MySQL-compatible, port 6001)
# For local development with docker-compose: mysql://root:111@127.0.0.1:6001/skynet
DATABASE_URL="mysql://root:111@127.0.0.1:6001/skynet"

# GitHub OAuth (create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# Auth
JWT_SECRET="your_jwt_secret"

# GitHub Webhook (used to verify incoming webhooks)
GITHUB_WEBHOOK_SECRET="your_github_webhook_secret"

# GitHub Personal Access Token (for API calls: sync issues, PRs)
GITHUB_TOKEN="your_github_token"

# AI Provider — MagikCloud (DeepSeek-compatible, OpenAI protocol)
AI_API_KEY="your_ai_api_key"

# App URL (used for OAuth callbacks, links, etc.)
# Local dev:          http://localhost:3000
# Cloudflare tunnel:  http://skynet.latentvibe.com
APP_URL="http://localhost:3000"

# AIO Sandbox (port must match docker-compose SANDBOX_PORT, default 8180)
SANDBOX_URL="http://localhost:8180"
